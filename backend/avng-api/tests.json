{
  "tests": [
    {
      "name": "Login wrong creds",
      "method": "POST",
      "path": "/?action=login",
      "body": {"action": "login", "login": "nobody", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный логин или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get users",
      "method": "POST",
      "path": "/",
      "body": {"action": "get_users"},
      "expectedStatus": 200,
      "expectedBody": {"users": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get reports",
