    },
    {
      "name": "Get exams",
      "method": "POST",
      "path": "/",
      "body": {"action": "get_exams"},
      "expectedStatus": 200,
      "expectedBody": {"exams": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get blacklist",
      "method": "POST",
